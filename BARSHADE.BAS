10 'FILENAME BARSHADE
20 'SHADES RECT, OMITS CORNERS
25 COLOR 4: SCREEN 9
30 KEY OFF: CLS
40 '
50 'SPECIFY RECTANGLE TO BE SHADED
60 INPUT "ENTER X1,Y1:   ", X1, Y1
70 INPUT "ENTER X2,Y2:   ", X2, Y2
80 '
90 'SPECIFY INCLINATION AND PITCH
100 INPUT "ENTER +/- INCLINATION:   ", I
110 INPUT "ENTER PITCH:   ", P
120 IF P < 1 THEN BEEP: GOTO 110
130 CLS
140 '
150 'DRAW RECTANGLE TO BE SHADED
160 LINE (X1, Y1)-(X2, Y2), , B
170 '
180 'SELECT ROUTINE FOR + OR - PITCH
190 IF I > 0 GOTO 290: 'POS INCLINE
200 '
210 'SHADE WITH NEG INCLINE
220 FOR ROW = Y1 + 1 TO Y2 + I - 1 STEP P
230 LINE (X1 + 1, ROW)-(X2 - 1, ROW - I), 1
240 NEXT
250 '
260 GOTO 320 'END
270 '
280 'SHADE WITH POS INCLINE
290 FOR ROW = Y1 + I + 1 TO Y2 - 1 STEP P
300 LINE (X1 + 1, ROW)-(X2 - 1, ROW - I), 1
310 NEXT
320 END















