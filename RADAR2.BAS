SCREEN 12
RANDOMIZE TIMER
DEF FNSPOT1$ = "NR1 NU1 ND1 NL1"
DEF FNSPOT2$ = "NR3 NU3 ND3 NL3"
DEF FNSPOT3$ = "NR8 NU8 ND8 NL8"
DEF FNSPOT4$ = "NR16 NU16 ND16 NL16"
X = 120: Y = 205
PSET (X, Y), 15
CIRCLE (319, 200), 200, 2
PAINT (1, 1), 0, 2
5 FOR T = .01 TO 6.28 STEP .01
CIRCLE (319, 200), 200, 10, -T, -T
PSET (X, Y), 0
IF (T MOD .04) = 0 THEN DRAW FNSPOT1$
IF (T MOD .04) = 1 THEN DRAW FNSPOT2$
IF (T MOD .04) = 2 THEN DRAW FNSPOT3$
IF (T MOD .04) = 3 THEN DRAW FNSPOT4$

FOR Z = 1 TO 200: NEXT Z
CIRCLE (319, 200), 200, 0, -T, -T
X = X + 1
IF POINT(X + 17, Y) = 2 THEN GOSUB 10
PSET (X, Y), 15
NEXT T
GOTO 5
10 R = RND * 5
SELECT CASE INT(R)
 CASE 0: X = 209: Y = 110
 CASE 1: X = 209: Y = 310
 CASE 2: X = 170: Y = 150
 CASE 3: X = 170: Y = 350
 CASE 4: X = 120: Y = 195
 CASE 5: X = 120: Y = 205
END SELECT
RETURN

