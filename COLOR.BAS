REM***COLOR TEST- SHOWS EVERY COLOR POSSIBLE IN QBASIC
SCREEN 13
CLS
DO
FOR T = 44 TO 39 STEP -1
COLOR T
PRINT CHR$(219);
NEXT T
COLOR 4
PRINT CHR$(219);
COLOR 113
PRINT CHR$(219);
LOOP UNTIL (INKEY$ <> "")

WHILE (INKEY$ = "")
LC = RND * 24
FOR T = 31 TO 16 STEP -1
COLOR T
PRINT CHR$(219);
PRINT
PRINT
NEXT T
WEND


