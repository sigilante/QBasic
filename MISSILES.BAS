'filename MISSILES
SCREEN 1: COLOR 9: KEY OFF: CLS
FOR I = 1 TO VAL(RIGHT$(TIME$, 2)): Z = RND: NEXT
DEFINT A-Z
DIM TARGET%(105)
INCX = 1: INCY = -1
ROT = 0
M$ = "A0 NL4 ND4 C0 BG10 NH4 NF4 BG6 NU8 ND3 BE16"
CIRCLE (250, 50), 30, 1, , , .2
PAINT STEP(0, 0), 2, 1
LINE (225, 49)-(235, 50), 3, B
LINE (245, 49)-(255, 50), 2, B
LINE (265, 49)-(275, 50), 3, B
GET (220, 44)-(280, 56), TARGET%
PUT (220, 44), TARGET%, XOR
XT1 = 220: YT1 = 44: XT2 = 50: YT2 = 100
PUT (XT1, YT1), TARGET%, XOR
PUT (XT2, YT2), TARGET%, XOR
280 X = 20 + (250 - RND * 250)
Y = 190
COLR = 2
330 X = X + INCX: Y = Y + INCY
PSET (X, Y), 0
DRAW "C2 X" + VARPTR$(M$)
IF X = 319 THEN INCX = -1: ROT = 1: Y = 50 + (RND * 140)
IF POINT(X - 6, Y - 1) = 1 OR POINT(X + 6, Y - 2) = 1 THEN COLOR 4: SOUND 1777, 4: SOUND 32767, 1: COLOR 1: SOUND 237, 7: SOUND 32767, 2
IF Y = 155 OR Y = 105 OR Y = 90 OR Y = 2 THEN GOSUB 600
IF Y = 16 THEN COLR = 0
IF Y = 0 THEN ROT = 0: INCX = 1: GOTO 280
GOTO 330
600 RETURN

