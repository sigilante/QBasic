10 SCREEN 12: RANDOMIZE TIMER: COLOR 2: POKE 49234, 0
20 FOR Y = 191 TO 170 STEP -1
30 LINE (0, Y)-(279, Y): NEXT
40 X = INT(RND * 200) + 40
50 FOR Y = 170 TO 20 STEP -1
60 X = X + INT(RND * 3) - 1
70 LINE (X, Y)-(X + 1, Y)
80 IF RND < .08 THEN GOSUB 120
90 NEXT
100 LINE (X, Y)-(X + 15 * SIN(A), Y + 15 * COS(A))
110 END
120 D = X + 30: IF RND < .5 THEN D = X - 30
130 LINE STEP(0, 0)-(D, Y - 5): FOR L = 0 TO 6.3 STEP .1
140 B = 3 * COS(L)
150 A = (3 + RND * 9) * SIN(L)
160 LINE (D, Y - 5)-(A + D, Y + B - 5)
170 NEXT: RETURN

