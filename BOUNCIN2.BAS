SCREEN 12
DEF SEG = 0
Status% = PEEK(&H417)
POKE &H417, (Status% OR &H40)
COLOR 10
PRINT "THIS IS A REMINDER: OCCASIONALY, IF YOU DO THIS PROGRAM FOR A LONG"
PRINT "TIME, PRESS <Ctrl> + <Pause/Break> AND THEN HIT <F5>. TO STOP, HIT"
PRINT "<Ctrl> + <Pause/Break>. THANK YOU."
INPUT "BALL COLOR(1-15)"; A%
INPUT "# OF DOTS(HIT '0' FOR NONE, 4000 IS NICE)"; C%
IF C% = 0 THEN GOTO 5 ELSE INPUT "COLOR OF DOTS"; I%: GOTO 10
5 I% = 3
10 INPUT "SOUND(Y/N)"; D$
INPUT "BORDER COLOR(1-15)"; E%
INPUT "FILL BALL WITH COLOR(Y/N)"; F$
IF F$ = "Y" THEN INPUT "FILL BALL WITH WHAT COLOR(1-15)"; G%
15 INPUT "RADIUS OF BALL(1-75)"; H%
IF H% > 75 THEN 15
CLS
X = 200
Y = 251
DX = 1: DY = 1
LINE (639, 479)-(0, 0), E%, B
FOR DOT = 1 TO C%: PSET (RND * 639, RND * 479), E%: NEXT DOT
DO
IF POINT(X + H% + 1, Y) = E% OR POINT(X - H% - 1, Y) = E% THEN DX = -DX
IF POINT(X, Y - H% - 1) = E% OR POINT(X, Y + H% + 1) = E% THEN DY = -DY
IF POINT(X + H% + 1, Y) = I% OR POINT(X - H% - 1, Y) = I% THEN DX = -DX
IF POINT(X, Y - H% - 1) = I% OR POINT(X, Y + H% + 1) = I% THEN DY = -DY
CIRCLE (X, Y), H%, A%
PAINT (X, Y), G%, A%
IF D$ = "Y" THEN SOUND RND * 32767, 1
PAINT (X, Y), 0, E%
X = X + DX
Y = Y + DY
LOOP UNTIL (INKEY$ <> "")




