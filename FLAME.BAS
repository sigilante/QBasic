SELECT CASE INKEY$
CASE "R": GOSUB MoveRight2
CASE "L": GOSUB MoveLeft2
CASE "P": GOSUB PauseGame2
CASE "F": GOSUB FireAndAmmo2
CASE "?": Help
CASE "X": EXIT DO
END SELECT
LOOP UNTIL (INKEY$ = "X")
MoveRight2:
CLS
DrawScreen2
X = X + 10
Y = 90
CIRCLE (X, Y), 10, 4
PAINT (X, Y), 1, 4
IF X > 310 THEN GOSUB NextScreen2
RETURN
MoveLeft2:
CLS
DrawScreen2
X = X - 10
Y = 90
CIRCLE (X, Y), 10, 4
PAINT (X, Y), 1, 4
RETURN
PauseGame2:
PRINT "Press any key to continue..."
DO
LOOP UNTIL (INKEY$ <> " ")
RETURN
FireAndAmmo2:
CIRCLE (X, Y), 10, 43
PAINT (X, Y), 39, 43
FOR T = 1 TO 25000: NEXT T
CIRCLE (X, Y), 10, 4
PAINT (X, Y), 32, 4
FIRE = 1
RETURN
NextScreen2:
newscreen2 = newscreen2 - 1
IF newscreen2 = 0 THEN Level3
FIRE = 0
DrawScreen2
X = 10
Y = 90
CIRCLE (X, Y), 10, 4
PAINT (X, Y), 9, 4
RETURN

SUB DrawScreen
LINE (0, 99)-(319, 199), 66, BF
'PAINT (10, 10), 100, 66
IF FIRE = 0 THEN DRAW "BM 100,100 C63 U40"
END SUB

SUB DrawScreen2
LINE (0, 100)-(319, 100), 45
PAINT (0, 0), 32, 45
PAINT (0, 150), 45, 45
IF FIRE = 0 THEN DRAW "BM 100,100 C64 U40"
END SUB

SUB DrawScreen3
LINE (0, 99)-(319, 199), 53, BF
PAINT (10, 10), 92, 53
IF FIRE = 0 THEN DRAW "BM 100,100 C65 U40"
END SUB

SUB Help
CLS
LINE (0, 0)-(319, 199), 31, B
LINE (2, 2)-(317, 197), 31, B
LINE (4, 4)-(315, 195), 31, B
PRINT
PRINT TAB(5); "THIS IS THE GAME OF FLAME WORLD."
PRINT TAB(5); "TO MOVE LEFT, PRESS 'L'. TO"
PRINT TAB(5); "MOVE RIGHT, PRESS 'R'. YOU CAN'T"
PRINT TAB(5); "MOVE UP AND DOWN. PRESS 'P' TO PAUSE "
PRINT TAB(5); "THE GAME. 'X' ENDS THE GAME. '?'"
PRINT TAB(5); "GETS YOU TO THIS SCREEN. 'F' FIRES."
PRINT TAB(5); "PRESS ENTER TO RETURN TO"
PRINT TAB(5); "PLAY. YOU SHOULD CONTINUE WHERE "
PRINT TAB(5); "YOU LEFT OFF."
INPUT A$
END SUB

SUB Level3
CLS
PRINT STRING$(40, CHR$(1))
PRINT CHR$(1); "  THE THIRD LEVEL AWAITS............. "; CHR$(1)
PRINT STRING$(40, CHR$(1))
FOR T = 1 TO 25000: NEXT T
newscreen3 = 5
DO
DrawScreen3
SELECT CASE INKEY$
CASE "R": GOSUB MoveRight3
CASE "L": GOSUB MoveLeft3
CASE "P": GOSUB PauseGame3
CASE "F": GOSUB FireAndAmmo3
CASE "?": Help
CASE "X": EXIT DO
END SELECT
LOOP UNTIL (INKEY$ = "X")
MoveRight3:
CLS
DrawScreen3
X = X + 10
Y = 90
CIRCLE (X, Y), 10, 4, , , 1.14325
PAINT (X, Y), 1, 4
IF X > 310 THEN GOSUB NextScreen3
RETURN
MoveLeft3:
CLS
DrawScreen3
X = X - 10
Y = 90
CIRCLE (X, Y), 10, 4, , , 1.14325
PAINT (X, Y), 1, 4
RETURN
PauseGame3:
PRINT "Press any key to continue..."
DO
LOOP UNTIL (INKEY$ <> " ")
RETURN
FireAndAmmo3:
CIRCLE (X, Y), 10, 43, , , 1.14325
PAINT (X, Y), 39, 43
FOR T = 1 TO 25000: NEXT T
CIRCLE (X, Y), 10, 4, , , 1.14325
PAINT (X, Y), 32, 4
FIRE = 1
RETURN
NextScreen3:
newscreen3 = newscreen3 - 1
IF newscreen3 = 0 THEN GOTO Level4
FIRE = 0
DrawScreen3
X = 10
Y = 90
CIRCLE (X, Y), 10, 4, , , 1.14325
PAINT (X, Y), 9, 4
RETURN
Level4:
END
END SUB

