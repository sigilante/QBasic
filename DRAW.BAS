REM***DRAW PROGRAM
PRINT "CHOICE A, B, OR C"; : INPUT C$
IF C$ = "A" THEN 10
IF C$ = "B" THEN 20 ELSE 30
10 SCREEN 13
LOCATE 1, 1: INPUT "ROW(1-24)"; i%
INPUT "COLUMN(1-39)"; j%
INPUT "COLOR(0-255)"; k%
IF i% < 1 OR i% > 24 THEN END
IF j% < 1 OR j% > 39 THEN END
IF k% < 0 OR k% > 255 THEN END
LOCATE i%, j%
COLOR k%
PRINT CHR$(219)
GOTO 10
20 SCREEN 12: WIDTH 80, 60
LOCATE 1, 1: INPUT "ROW(1-59)"; i%
INPUT "COLUMN(1-79)"; j%
INPUT "COLOR(0-15)"; k%
IF i% < 1 OR i% > 59 THEN END
IF j% < 1 OR j% > 79 THEN END
IF k% < 0 OR k% > 15 THEN END
LOCATE i%, j%
COLOR k%
PRINT CHR$(219)
GOTO 20
30 SCREEN 12: WIDTH 80, 60
LOCATE 1, 1: INPUT "ROW(1-24)"; i%
INPUT "COLUMN(1-39)"; j%
INPUT "CHARACTER #(0-255)"; k%
IF i% < 1 OR i% > 59 THEN END
IF j% < 1 OR j% > 79 THEN END
IF k% < 0 OR k% > 255 THEN END
LOCATE i%, j%
PRINT CHR$(k%)
GOTO 30






