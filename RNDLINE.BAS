SCREEN 12
RANDOMIZE TIMER
PAINT (0, 0), 6
PSET (0, 0), RND * 15
DO
I% = INT(RND * 7)
 SELECT CASE I%
  CASE 0: DRAW "U"
  CASE 1: DRAW "E"
  CASE 2: DRAW "R"
  CASE 3: DRAW "F"
  CASE 4: DRAW "D"
  CASE 5: DRAW "G"
  CASE 6: DRAW "L"
  CASE 7: DRAW "H"
 END SELECT
LOOP UNTIL (INKEY$ = CHR$(27))

