'FILENAME: DRAWALOT.BAS
'
'LETS USER SKETCH A COLORFUL LINE DRAWING
'ON-SCREEN
'THE FIRST VALUE DESIGNATES THE BACKGROUND COLOR

SCREEN 12   '640 x 360 RESOLUTION
DO
   USERKEY$ = INKEY$
   SELECT CASE UCASE$(USERKEY$)
      CASE "U": DRAW "U"
      CASE "D": DRAW "D"
      CASE "L": DRAW "L"
      CASE "R": DRAW "R"
      CASE "Q": EXIT DO
      CASE "E": DRAW "E"
      CASE "G": DRAW "G"
      CASE "F": DRAW "F"
      CASE "H": DRAW "H"
      CASE "0" TO "9": DRAW "C" + USERKEY$  'APPEND COLOR
   END SELECT                               'NUMBER TO STRING
LOOP UNTIL (UCASE$(USERKEY$) = "Q")

SCREEN 0 'RESTORES SCREEN TO 80 x 25 TEXT

