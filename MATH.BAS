SCREEN 12: CLS : RANDOMIZE TIMER
FOR T% = 2 TO 12
 FOR U% = 1 TO 12
MathFunc:
  PRINT T%; "x"; U%; "="; : INPUT G%
  IF G% = (T% * U%) THEN
   H% = (RND * 4)
   SELECT CASE INT(H%)
    CASE 0: COLOR 14: PRINT "GOOD WORK!": COLOR 15
     PLAY "L8CDEFEDCDEE"
    CASE 1: COLOR 9: PRINT "YOU DID IT!": COLOR 15
     PLAY "L8CDEFEDCDEE"
    CASE 2: COLOR 10: PRINT "YOU ARE RIGHT!": COLOR 15
     PLAY "L8CEGFDFECCC4"
    CASE ELSE: COLOR 11: PRINT "CORRECT!": COLOR 15
     PLAY "L8ABABGFEDC2"
   END SELECT
  ELSE
   BEEP: BEEP: BEEP
   COLOR 4: PRINT "TRY AGAIN!": COLOR 15
   GOTO MathFunc
  END IF
  
   NEXT U%
   NEXT T%

