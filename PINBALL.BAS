DOIT:
X = (51 + (RND * 5))
Y = (51 + (RND * 5))
DX = 1
DY = 1
GOSUB SCREEN4
DO
IF POINT(X + 21, Y) = 9 OR POINT(X - 21, Y) = 9 THEN DX = -DX
IF POINT(X, Y + 21) = 9 OR POINT(X, Y - 21) = 9 THEN DY = -DY
CIRCLE (X, Y), 20, 7
PAINT (X, Y), 8, 7
FOR T = 1 TO 200: NEXT T
PAINT (X, Y), 0, 9
X = X + DX
Y = Y + DY
SELECT CASE UCASE$(INKEY$)
 CASE "1": CLS : GOSUB SCREEN1
 CASE "2": CLS : GOSUB SCREEN2
 CASE "3": CLS : GOSUB SCREEN3
 CASE "4": CLS : GOSUB SCREEN4
 CASE CHR$(27): EXIT DO
END SELECT
LOOP UNTIL (INKEY$ = CHR$(27))
END
