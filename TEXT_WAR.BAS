CLS : WIDTH 80
X = 1
Y = 1
MAN = 195
DO
COLOR 10
LOCATE X, Y: PRINT CHR$(MAN)
LOCATE X, Y: PRINT " "
SELECT CASE INKEY$
 CASE "X": EXIT DO
 CASE "L": Y = Y - 2: MAN = 180
 CASE "R": Y = Y + 2: MAN = 195
 CASE "U": X = X - 2: MAN = 193
 CASE "D": X = X + 2: MAN = 194
 CASE "F": GOSUB FIRE
END SELECT
LOOP UNTIL (INKEY$ = "X")
END
FIRE:
SELECT CASE MAN
  CASE MAN = 180: GOTO FIREL
  CASE MAN = 195: GOTO FIRER
  CASE MAN = 193: GOTO FIREU
  CASE MAN = 194: GOTO FIRED
END SELECT
FIREL:
 LOCATE X + 1, Y: COLOR 4: PRINT "ł"
 FOR T = 1 TO 2000: NEXT T
 LOCATE X + 1, Y: PRINT " "
RETURN
FIRER:
 LOCATE X - 1, Y: COLOR 4: PRINT "ł"
 FOR T = 1 TO 2000: NEXT T
 LOCATE X - 1, Y: PRINT " "
RETURN
FIREU:
 LOCATE X, Y + 1: COLOR 4: PRINT "Ä"
 FOR T = 1 TO 2000: NEXT T
 LOCATE X, Y + 1: PRINT " "
RETURN
FIRED:
 LOCATE X, Y - 1: COLOR 4: PRINT "Ä"
 FOR T = 1 TO 2000: NEXT T
 LOCATE X, Y - 1: PRINT " "
RETURN

