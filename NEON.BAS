SUB Puzzle1
CLS
DETONATE = 5
D = INT(RND * 9)
PRINT "THIS FIRST PUZZLE IS EASY. ALL YOU HAVE TO DO IS GUESS THE DISARMING"
PRINT "CODE TO THE BOMB. THE CODE IS A NUMBER BETWEEN 1 AND 9! YOU HAVE 5"
PRINT "TRIES. AFTER THAT, YOU'RE CYBER-DUST..."
10 INPUT "WHAT IS YOUR GUESS"; C
IF C = D THEN 15 ELSE DETONATE = DETONATE - 1
IF DETONATE <> 0 THEN 10 ELSE PRINT "BOOOOOMMMM!!!!": END
15 PRINT "YOU DISARMED THE BOMB!!! TRY THE NEXT PUZZLE!!!"
PLAYTIME = PLAYTIME + 1
FOR T = 1 TO 25000: NEXT T
END SUB

SUB Puzzle2
23 CLS
