DEFINT A-Z
SUB SparklePause
A$ = "*   *   *   *   *   *   *   *   *   *   *   *   *   *   *   *   *   *   *   *"

    WHILE INKEY$ = ""
        FOR A = 1 TO 5
            LOCATE 1, 1                             'print horizontal sparkles
            PRINT MID$(A$, A, 80);
            LOCATE 22, 1
            PRINT MID$(A$, 6 - A, 80);

            FOR B = 2 TO 21                         'Print Vertical sparkles
                C = (A + B) MOD 5
                IF C = 1 THEN
                    LOCATE B, 80
                    PRINT "*";
                    LOCATE 23 - B, 1
                    PRINT "*";
                ELSE
                    LOCATE B, 80
                    PRINT " ";
                    LOCATE 23 - B, 1
                    PRINT " ";
                END IF
            NEXT B
        NEXT A
    WEND

END SUB

