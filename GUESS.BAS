SCREEN 12
DEF FNHEART$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 R3 D3 C4 R2 F2 R1 E2 R2 F2 D3 G6 H6 U4 E1 BD2 P4,4"
DEF FNCHERRY$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 R1 D7 C4 D4 F1 D1 F1 R6 E2 U3 H1 L1 H2 U1 L4 G1 BF1 P4,4 BH1 E1 R4 D1 F1 C2 E5 R1"
DEF FNBELL$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 R7 D2 C0 D5 R1 NU5 BD1 C9 R1 F1 D3 F1 G1 L1 G1 L1 H1 L1 H1 E1 U3 E1 R1 BD1 P9,9"
DEF FNLEMON$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 D7 C0 R1 E3 R1 E1 R3 F1 R1 F3 R1 D1 L1 G3 L1 G1 L3 H1 L1 H3 L1 BR5 P14,0"
DEF FNDIAMOND$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 D7 R1 C2 E6 R1 F6 D1 G6 L1 H6 BR5 P2,2"
DEF FNBAR$ = "C15 R15 D15 L15 U15 BF1 P15,15 BH1 D5 R1 C1 R13 D5 L13 U5 BF1 P1,1"
M% = 500
RANDOMIZE TIMER
GO:
 LINE (0, 150)-(215, 165), 15, BF
 PRINT "YOU HAVE"; M%; "POINTS. PRESS ENTER TO ROLL PICTURE DICE..."; : LINE INPUT AXLE$
 IF AXLE$ = "X" THEN END
 IF AXLE$ = "O" THEN M% = 500
 A% = RND * 5: B% = RND * 5: C% = RND * 5
 SELECT CASE A%
  CASE 0: DRAW "BM 150,150" + FNHEART$
  CASE 1: DRAW "BM 150,150" + FNCHERRY$
  CASE 2: DRAW "BM 150,150" + FNBELL$
  CASE 3: DRAW "BM 150,150" + FNLEMON$
  CASE 4: DRAW "BM 150,150" + FNDIAMOND$
  CASE 5: DRAW "BM 150,150" + FNBAR$
 END SELECT
 SELECT CASE B%
  CASE 0: DRAW "BM 50,150" + FNHEART$
  CASE 1: DRAW "BM 50,150" + FNCHERRY$
  CASE 2: DRAW "BM 50,150" + FNBELL$
  CASE 3: DRAW "BM 50,150" + FNLEMON$
  CASE 4: DRAW "BM 50,150" + FNDIAMOND$
  CASE 5: DRAW "BM 50,150" + FNBAR$
 END SELECT
 SELECT CASE C%
  CASE 0: DRAW "BM 100,150" + FNHEART$
  CASE 1: DRAW "BM 100,150" + FNCHERRY$
  CASE 2: DRAW "BM 100,150" + FNBELL$
  CASE 3: DRAW "BM 100,150" + FNLEMON$
  CASE 4: DRAW "BM 100,150" + FNDIAMOND$
  CASE 5: DRAW "BM 100,150" + FNBAR$
 END SELECT
IF A% = B% AND B% = C% THEN M% = M% + 500: GOTO X
IF A% = B% OR A% = C% OR B% = C% THEN M% = M% + 100
IF A% <> B% AND B% <> C% AND A% <> C% THEN M% = M% - 50
X:
LINE INPUT AXLE$
CLS
GOTO GO

