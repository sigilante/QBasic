10 REM***COLORDEM PROGRAM
20 'DISPLAYS ALL COLORS IN MED-RES MODE
30 SCREEN 13: KEY OFF: CLS
40 '
50 'LOOPS TO SET COLORS
60 FOR BACK = 0 TO 255: 'BACKGROUND
80 COLOR BACK: 'SET COLOR
90 CLS
100 '
110 'DISPLAYS COLORS
120 LOCATE 1, 2: PRINT "COLORS IN MEDIUM RESOLUTION/256 MODE"
130 '
140 'DISPLAY COLOR AND SCREEN STATEMENT
150 LOCATE 3, 4: PRINT "SCREEN 13"; SPC(11); "COLOR "; BACK
160 LOCATE 5, 8: PRINT "BACKGROUND IS COLOR 0": LOCATE 6, 8: PRINT "CHARACTERS ARE COLOR 3"
170 '
180 'DISPLAYS COLORS IN BOXES
190 'LINE (50, 60)-(250, 90), 1, BF
200 'LINE (50, 100)-(250, 130), 2, BF
210 'LINE (50, 140)-(250, 170), 3, BF
220 '
230 'PRINT COLOR LABELS IN BOXES
240 LOCATE 10, 12: PRINT "PALETTE COLOR 1"
250 LOCATE 15, 12: PRINT "PALETTE COLOR 2"
260 LOCATE 20, 12: PRINT "PALETTE COLOR 3"
270 '
280 'DISPLAY INSTRUCTION
290 LOCATE 24, 7: PRINT "TO CONTINUE, PRESS <ENTER>";
300 A$ = INPUT$(1)
310 '
330 NEXT BACK
340 '
350 'END ROUTINE
360 COLOR 1: CLS
370 LOCATE 10, 10: PRINT "END OF DEMONSTRATION"
380 LOCATE 20

