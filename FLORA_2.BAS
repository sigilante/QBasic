1 SCREEN 1
5 RANDOMIZE TIMER
10 PI = 3.1416
20 R = RND * 70 + 5
25 X = RND * 640
30 Y = RND * 479
35 C = RND * 3: COLOR 9, C
40 IF R + X > 319 OR X - R < 0 THEN 20
50 IF R + Y > 199 OR Y - R < 0 THEN 20
60 FOR A = 0 TO 2 * PI STEP PI / R
70 XC = R * COS(A): YC = R * SIN(A)
80 LINE (X, Y)-(X + XC, Y + YC)
90 NEXT
95 F = F + 1
100 IF F > 200 THEN CLS : F = 0
110 GOTO 20

