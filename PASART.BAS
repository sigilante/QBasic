CLS
PRINT TAB(24); "PASART"
PRINT TAB(19); "GAME WRIGHT, INC."
PRINT TAB(21); "PLAINVIEW, TX"
PRINT : PRINT : PRINT
DIM P(36, 36)
FOR B1 = 1 TO 36
FOR B2 = 1 TO 36
P(B1, B2) = O
NEXT B2
NEXT B1
PRINT "THIS PROGRAM CREATES TRIANGLES BASED ON PASCAL'S TRIANGLE."
PRINT "YOU HAVE 3 BASIC TYPES OF TRIANGLES TO CHOOSE FROM:"
PRINT " 1.ONE PASCAL'S TRIANGLE(PLAYED WITH AN ARTISTIC FLARE)"
PRINT " 2.TWO 'ARTSY' PASCAL'S TRIANGLES PRINTED BACK TO BACK"
PRINT " 3.FOUR 'ARTSY' PASCAL'S TRIANGLES PRINTED IN THE CORNER OF A "
PRINT " SQUARE ARRAY"
100 PRINT "WHAT'S YOUR CHOICE(1,2, OR 3)"; : INPUT O
IF (O - 1) * (O - 2) * (O - 3) <> 0 THEN 100
PRINT "WHICH MULTIPLES DO YOU WANT REPRESENTED WITH BLANKS"; : INPUT Q
150 PRINT "HOW MANY ROWS AND COLUMNS IN THE ARRAY(36 IS MAX)"; : INPUT T
PRINT "WHAT CHARACTER DO YOU WANT USED"; : INPUT CH$
IF T * (36 - T) < 0 THEN 150
ON O GOTO 230, 440, 690
'
'
'
'TRIANGLE #1
230 FOR R = 1 TO T
FOR C = 1 TO T
IF (R - 1) * (C - 1) = 0 THEN 280
P(R, C) = P(R, C - 1) + P(R - 1, C)
GOTO 290
280 P(R, C) = 1
290 NEXT C
NEXT R
'TIME FOR THE "ARTISTIC FLARE"
320 FOR R = 1 TO T
FOR C = 1 TO T
IF P(R, C) = 0 THEN 380
IF (P(R, C) / Q) = INT(P(R, C) / Q) THEN 380
LPRINT CH; " ";
GOTO 390
380 LPRINT "  ";
390 NEXT C
PRINT
NEXT R
END
'TIME FOR THE DOUBLE PIECE OF PASART
440 Z = T
'UPPER LEFT HAND OF ARRAY
LET N = Z
FOR R = 1 TO N
FOR C = 1 TO Z - 1
IF (R - 1) * (C - 1) = 0 THEN 520
P(R, C) = P(R, C - 1) + P(R - 1, C)
GOTO 530
520 P(R, C) = 1
530 NEXT C
Z = Z - 1
NEXT R
'LOWER RIGHT HAND
Z = N
N = 2
FOR R = Z TO 1 STEP -1
FOR C = Z TO N STEP -1
IF (R - Z) * (C - Z) = 0 THEN 640
P(R, C) = P(R, C + 1) + P(R + 1, C)
GOTO 650
640 P(R, C) = 1
650 NEXT C
N = N + 1
NEXT R
GOTO 320
690 M = Q
'UPPER LEFT HAND
Y = T
Z = INT(Y / 2)
B5 = Z * 2
Z1 = Z
Z2 = Z1
Z3 = Z2
X4 = Z3
X5 = X4
FOR I = 1 TO Z1
FOR J = 1 TO Z
IF (J - 1) * (I - 1) = 0 THEN 840
P(I, J) = P(I, J - 1) + P(I - 1, J)
GOTO 850
840 P(I, J) = 1
850 NEXT J
Z = Z - 1
NEXT I
N = Z1
'UPPER RIGHT HAND
FOR I = 1 TO Z1
FOR J = Y TO X5 + 1 STEP -1
IF I = 1 THEN 960
IF J = Y THEN 960
P(I, J) = P(I, J + 1) + P(I + 1, J)
GOTO 970
960 P(I, J) = 1
970 NEXT J
X5 = X5 + 1
NEXT I
N = Z2
'LOWER LEFT CORNER
FOR I = Y TO X4 + 1 STEP -1
FOR J = 1 TO Z2
IF J = 1 THEN 1080
IF I = 1 THEN 1080
P(I, J) = P(I, J - 1) + P(I + 1, J)
GOTO 1090
1080 P(I, J) = 1
1090 NEXT J
Z2 = Z2 - 1
NEXT I
N = Z3
'LOWER RIGHT HAND
FOR I = Y TO N + 1 STEP -1
FOR J = Y TO Z3 + 1 STEP -1
IF J = Y THEN 1200
IF I = Y THEN 1200
P(I, J) = P(I + 1, J) + P(I, J + 1)
GOTO 1210
1200 P(I, J) = 1
1210 NEXT J
Z3 = Z3 + 1
NEXT I
GOTO 320
END


