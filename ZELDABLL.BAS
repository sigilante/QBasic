SCREEN 13
DIM LINK%(150)
DIM XIT%(150)
DEF FNBALL1$ = "C8 R3 F1 R2 L1 D1 F1 R1 U1 L1 C48 L0 C8 BL1 H2 L3 G1 L1 G2 D2"
DEF FNBALL2$ = "R2 E1 R4 F1 R2 U2 R2 D5 G4 L6 H4 U5 R2 D3 F1 R1 E1 R4 F1 R1 E1"
DEF FNBALL3$ = "BL4 BD2 D1 BL2 U1 BU5 P48,8 BD2 P39,8 BL1 BG1 P39,8 BR6 P39,8"
DEF FNBALL4$ = "BR3 P66,8 BD3 BL4 C15 U2 L1 BL2 L1 D2"
'1,104,199
GOTO IT
DS1:
DRAW "BM 0,0 C1 D199 R120 U50 BR75 D50 R124 U199 L319 BF1 C104 D197 R118 U50 R2 D51 BR73 U51"
DRAW "R2 D50 R122 U197 L317 BF1 C199 D195 R116 U50 R4 D52 BR71 U52 R4 D50 R120"
DRAW "U195 L315"
RETURN
IT:
PSET (10, 4), 0
DRAW FNBALL1$ + FNBALL2$ + FNBALL3$ + FNBALL4$
GET (4, 4)-(18, 16), LINK%
LINE (10, 4)-(18, 16), 0, BF
GET (10, 4)-(18, 16), XIT%
CLS
X1 = 50: Y1 = 50
DX = 1: DY = 1
B = 50
DO
GOSUB DS1
LINE (0, 199)-(319, 199), 199, B
IF POINT(X1 - 1, Y1) = 199 OR POINT(X1 + 15, Y1) = 199 THEN DX = -DX: B = B + 1
IF POINT(X1, Y1 - 1) = 199 OR POINT(X1, Y1 + 15) = 199 THEN DY = -DY: B = B + 1
IF Y1 > 191 THEN L = L - 1: X = 50: Y = 50: GOTO IT
IF B > 50 THEN LOCATE 1, 1: PRINT "GOOD!": A$ = INPUT$(1): B = 0: G = G + 1
IF G > 10 THEN LOCATE 1, 1: PRINT "LINK SAYS GREAT! NOW BEAT GANON!": A$ = INPUT$(1)
X1 = X1 + (DX)
Y1 = Y1 + (DY)
PUT (X1, Y1), LINK%
PAINT (X1, Y1), 0, 199
LOOP UNTIL (INKEY$ <> "")

