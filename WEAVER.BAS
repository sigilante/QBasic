10 REM***WEAVER
20 SCREEN 13, 0: COLOR 8: KEY OFF: CLS
30 '
40 'SET START AND INCREMENTS
50 X = 50: Y = 50 + VAL(RIGHT$(TIME$, 2))
60 INCX = 2: INCY = 1:
70 '
80 'TEST FOR BOUNDARY
90 IF X = 50 THEN INCX = 2: COLR = COLR + 1
100 IF Y = 50 THEN INCY = 1: COLR = COLR + 1
110 IF X = 270 THEN INCX = -2: COLR = COLR + 1
120  IF Y = 140 THEN INCY = -1: COLR = COLR + 1
130 '
140 'DRAW RECT TO MOVE
150 COLR = (COLR MOD 3)
160 LINE (X, Y)-(X + 3, Y + 3), COLR + 1, BF
170 '
180 'MOVE
190 X = X + INCX: Y = Y + INCY
200 GOTO 90

