SUB Add
CLS
NUM = 1
DO
 A = RND * 10
 B = RND * 10
 C = A + B
5 PRINT "#"; NUM; ": "; A; " + "; B; " = "; : INPUT ANSWER$
 SELECT CASE ANSWER$
  CASE IS <> C$: PRINT "WRONG": GOTO 5
  CASE IS = C$:  BEEP
  CASE "Q": EXIT DO
 END SELECT
NUM = NUM + 1
LOOP UNTIL (INKEY$ = "Q")
END SUB

